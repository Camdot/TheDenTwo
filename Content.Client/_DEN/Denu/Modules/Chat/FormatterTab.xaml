<chat:FormatterTab xmlns="https://spacestation14.io"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:chat="clr-namespace:Content.Client._DEN.Denu.Modules.Chat"
                   xmlns:components="clr-namespace:Content.Client.UserInterface.Systems.Chat.Controls.Denu.Components">
    <BoxContainer Orientation="Vertical" SeparationOverride="8" HorizontalExpand="True">
        <BoxContainer Orientation="Horizontal" SeparationOverride="4">
            <CheckBox Name="AutoFormatterCheckBox" Text="Enable Auto-Formatter" />
        </BoxContainer>

        <BoxContainer Orientation="Horizontal" SeparationOverride="4">
            <CheckBox Name="RemoveAsterisksCheckBox" Text="Remove Asterisks" />
        </BoxContainer>

        <BoxContainer Orientation="Vertical" SeparationOverride="4">
            <Label Text="Dialogue Color:" />
            <ColorSelectorSliders Name="DialogueColorSelector" HorizontalExpand="True" />
        </BoxContainer>

        <BoxContainer Orientation="Vertical" SeparationOverride="4">
            <Label Text="Emote Color:" />
            <ColorSelectorSliders Name="EmoteColorSelector" HorizontalExpand="True" />
        </BoxContainer>

        <BoxContainer Orientation="Vertical" SeparationOverride="4">
            <Label Text="Preview:" />
            <PanelContainer StyleClasses="AngleRect">
                <BoxContainer Orientation="Vertical" Margin="6">
                    <RichTextLabel Name="PreviewRawLabel" />
                    <RichTextLabel Name="PreviewFormattedLabel" />
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>
    </BoxContainer>
</chat:FormatterTab>